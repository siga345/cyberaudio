generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum DemoVersionType {
  IDEA_TEXT
  DEMO
  ARRANGEMENT
  NO_MIX
  MIXED
  MASTERED
  RELEASE
}

enum ProjectCoverType {
  GRADIENT
  IMAGE
}

enum ProjectReleaseKind {
  SINGLE
  ALBUM
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  nickname  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  folders   Folder[]
  projects  Project[]
  tracks    Track[]
}

model Folder {
  id             String    @id @default(cuid())
  userId         String
  parentFolderId String?
  title          String
  pinnedAt       DateTime?
  sortIndex      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentFolder   Folder?   @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: SetNull)
  childFolders   Folder[]  @relation("FolderHierarchy")
  projects       Project[]
  tracks         Track[]

  @@index([parentFolderId])
  @@index([pinnedAt])
  @@index([userId, parentFolderId, updatedAt])
}

model Project {
  id             String             @id @default(cuid())
  userId         String
  folderId       String?
  title          String
  artistLabel    String?
  releaseKind    ProjectReleaseKind @default(ALBUM)
  coverType      ProjectCoverType   @default(GRADIENT)
  coverImageUrl  String?
  coverPresetKey String?
  coverColorA    String?
  coverColorB    String?
  pinnedAt       DateTime?
  sortIndex      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder         Folder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tracks         Track[]

  @@index([userId, updatedAt])
  @@index([folderId])
  @@index([pinnedAt])
}

model Track {
  id             String    @id @default(cuid())
  userId         String
  title          String
  lyricsText     String?
  folderId       String?
  projectId      String?
  primaryDemoId  String?
  pathStageId    Int?
  displayBpm     Float?
  displayKeyRoot String?
  displayKeyMode String?
  sortIndex      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder         Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  demos          Demo[]    @relation("TrackDemos")

  @@index([projectId, sortIndex])
  @@index([folderId, sortIndex])
  @@index([primaryDemoId])
}

model Demo {
  id              String          @id @default(cuid())
  trackId         String
  audioPath       String?
  textNote        String?
  duration        Int             @default(0)
  releaseDate     DateTime?
  detectedBpm     Float?
  detectedKeyRoot String?
  detectedKeyMode String?
  versionType     DemoVersionType @default(DEMO)
  sortIndex       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  track           Track           @relation("TrackDemos", fields: [trackId], references: [id], onDelete: Cascade)
  reflection      VersionReflection?

  @@index([trackId, versionType, sortIndex])
}

model VersionReflection {
  demoId          String   @id
  whyMade         String?
  whatChanged     String?
  whatNotWorking  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  demo            Demo     @relation(fields: [demoId], references: [id], onDelete: Cascade)
}
